---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tesis 01 | The Great Puzzle Project">
	<main class="min-h-screen bg-bg text-primary px-6 md:px-16 pt-32 pb-20">
		<div class="max-w-7xl mx-auto mb-20 flex justify-between items-center">
			<h1 class="font-gloock text-3xl md:text-5xl tracking-tighter uppercase titulo-estilo-apple">Tesis 01: El Sapiens Arquitecto</h1>
			<a href="/#tesis" class="cta-glass !rounded-full !px-8 !py-2 !text-[9px] uppercase tracking-widest group">
				<span class="group-hover:-translate-x-1 inline-block transition-transform">←</span> Volver
			</a>
		</div>

		<section class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
			<div class="lg:col-span-2 relative aspect-video rounded-[2.5rem] overflow-hidden bento-glass group">
				<img src="/tesis-01.png" alt="Sapiens Arquitecto" class="absolute inset-0 w-full h-full object-cover grayscale brightness-50 transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0 group-hover:brightness-75" />
				<div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-90"></div>
				<div class="absolute bottom-8 left-8 right-8">
					<h2 class="font-bodoni text-4xl md:text-6xl font-bold mb-4 titulo-estilo-apple tracking-tighter">I. El Sapiens Arquitecto</h2>
					<p class="font-inter text-sm md:text-base font-extralight leading-relaxed opacity-80 max-w-2xl">
						No habitamos mundos materiales, sino relatos. La civilización es un mecanismo de defensa neurocognitivo proyectado a escala monumental.
					</p>
				</div>
			</div>

			<div class="space-y-6">
				<div class="bento-glass p-8 rounded-[2rem] space-y-6">
					<h4 class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-40">Créditos</h4>
					<div class="space-y-4">
						<p class="text-xs font-bold">Investigación: <span class="opacity-50 font-normal">Xavier Benítez</span></p>
						<p class="text-xs font-bold">Categoría: <span class="opacity-50 font-normal">Antropología Filosófica</span></p>
					</div>
					<button class="w-full py-3 rounded-full border border-white/10 text-[9px] uppercase tracking-widest hover:bg-[#9F8CAE] transition-all">Seguir Investigación</button>
				</div>
			</div>
		</section>
	</main>
</Layout>
