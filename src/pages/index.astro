---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Great Puzzle Project | Landing">
	<!-- LENS GLOWS -->
	<div class="lens-glow top-[-200px] left-[-200px]"></div>
	<div class="lens-glow bottom-[-200px] right-[-200px]"></div>

	<!-- FIXED NAVBAR -->
	<nav class="fixed top-0 left-0 w-full z-50 border-b border-border/20 bg-bg/80 backdrop-blur-md px-6 py-6 flex justify-between items-center transition-all duration-500">
		<div class="flex items-center gap-4 group cursor-pointer">
			<img src="/puzzle.png" alt="Logo" class="h-8 w-auto brightness-150 grayscale group-hover:grayscale-0 transition-all duration-700" />
			<div class="font-gloock tracking-[0.15em] text-xl md:text-2xl uppercase titulo-estilo-apple">THE GREAT PUZZLE PROJECT</div>
		</div>
		<div class="hidden md:flex gap-12 text-[10px] uppercase tracking-ultra-wide font-light text-primary/80">
			<a href="#" class="hover:text-[#9F8CAE] transition-all duration-500 hover:tracking-[0.4em]">Xavier Benítez</a>
			<a href="#tesis" class="hover:text-[#9F8CAE] transition-all duration-500 hover:tracking-[0.4em]">Tesis</a>
			<a href="#media" class="hover:text-[#9F8CAE] transition-all duration-500 hover:tracking-[0.4em]">Media Lab</a>
			<a href="#" class="hover:text-[#9F8CAE] transition-all duration-500 hover:tracking-[0.4em]">Archivo</a>
		</div>
	</nav>

	<main class="relative z-10">
		<!-- HERO SECTION -->
		<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-20 overflow-hidden">
			<div class="absolute -z-10 opacity-5 w-[70%] max-w-[900px] pointer-events-none">
				<img src="/puzzle.png" alt="" class="w-full h-auto grayscale blur-[2px]" />
			</div>

			<h1 class="font-bodoni text-[10vw] md:text-[8vw] lg:text-[7vw] font-bold leading-[0.9] max-w-[95vw] mb-12 hero-title group cursor-default titulo-estilo-apple tracking-tighter">
				Comprender por qué <span class="italic highlight-word">pensamos</span> lo que pensamos.
			</h1>
			<p class="font-inter font-thin text-[11px] md:text-sm tracking-[0.5em] uppercase text-fade-gradient max-w-3xl leading-[2.5] hero-subtitle">
				Una investigación sobre la arquitectura técnica del olvido y la gestión del sentido en la era digital.
			</p>
			
			<div class="mt-16 flex flex-col md:flex-row gap-6 hero-subtitle">
				<a href="/tesis" class="cta-editorial">Explorar el Archivo</a>
				<a href="mailto:info@greatpuzzle.project" class="cta-glass">Consultoría</a>
			</div>
			
			<div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-pulse opacity-40">
				<div class="w-[1px] h-12 bg-border"></div>
			</div>
		</section>

		<!-- ABOUT SECTION (Spotify Artist Style) -->
		<section id="about" class="relative py-20 bg-bg px-6 md:px-16">
			<div class="max-w-6xl mx-auto">
				<div class="relative w-full aspect-video md:aspect-[21/9] rounded-[2rem] overflow-hidden bento-glass group">
					<!-- Artist Background Image -->
					<img src="/perfil.webp" alt="Xavier Benítez" class="absolute inset-0 w-full h-full object-cover grayscale brightness-50 transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0 group-hover:brightness-75" />
					
					<!-- Top Label -->
					<div class="absolute top-8 left-8 z-20">
						<span class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-60">Información sobre el autor</span>
					</div>

					<!-- Bottom Content -->
					<div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-80"></div>
					
					<div class="absolute bottom-8 left-8 right-8 z-20 flex flex-col md:flex-row md:items-end justify-between gap-8">
						<div class="max-w-2xl">
							<h2 class="font-bodoni text-5xl md:text-7xl font-bold mb-2 titulo-estilo-apple tracking-tighter">Xavier Benítez</h2>
							<div class="flex items-center gap-4 mb-6">
								<span class="font-inter text-xs tracking-widest uppercase opacity-60">1.2k lectores mensuales</span>
							</div>
							<p class="font-inter text-sm md:text-base font-extralight leading-relaxed opacity-80 max-w-xl line-clamp-3 md:line-clamp-none">
								Investigador y arquitecto de nichos simbólicos. Su trabajo se sitúa en la intersección de la neurohistoria, la antropología filosófica y la teoría técnica, cartografiando los procesos de exclusión y amnesia programada en la era digital.
							</p>
						</div>

						<a href="/proyectos" class="cta-glass !rounded-full !px-10 !py-3 !text-[10px] flex items-center gap-2 group/btn whitespace-nowrap">
							<span>Explorar Trayectoria</span>
							<span class="opacity-0 group-hover/btn:opacity-100 transition-opacity">→</span>
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- THESES SECTION -->
		<section id="tesis" class="relative py-32 bg-bg px-6 md:px-16 space-y-12">
			<div class="mb-24">
				<h2 class="font-bodoni text-5xl md:text-8xl leading-none titulo-estilo-apple italic tracking-tighter">
					Las Tesis del<br/><span class="italic highlight-word">Rompecabezas</span>
				</h2>
				<p class="font-inter text-[10px] tracking-[0.4em] uppercase opacity-40 mt-8">Arquitectura del sentido</p>
			</div>

			<div class="flex flex-col gap-12">
				<a href="/tesis-01" class="block thesis-card w-full bento-glass p-8 md:p-16 rounded-[3rem] card-lift group min-h-[400px] flex flex-col md:flex-row gap-16 items-center mask-image-v">
					<div class="text-7xl md:text-9xl font-bodoni italic opacity-5 group-hover:opacity-20 transition-opacity">01</div>
					<div class="flex-1">
						<h3 class="font-bodoni text-4xl md:text-6xl mb-8 uppercase tracking-tighter transition-transform duration-500 group-hover:translate-x-4 titulo-estilo-apple">
							I. El Sapiens <span class="highlight-word">Arquitecto</span>
						</h3>
						<p class="font-inter font-extralight text-lg md:text-2xl leading-relaxed opacity-60 group-hover:opacity-100 transition-opacity max-w-4xl">
							No habitamos mundos materiales, sino relatos. La civilización es un mecanismo de defensa neurocognitivo proyectado a escala monumental.
						</p>
					</div>
				</a>

				<a href="/tesis-02" class="block thesis-card w-full bento-glass p-8 md:p-16 rounded-[3rem] card-lift group min-h-[400px] flex flex-col md:flex-row gap-16 items-center mask-image-v">
					<div class="text-7xl md:text-9xl font-bodoni italic opacity-5 group-hover:opacity-20 transition-opacity">02</div>
					<div class="flex-1">
						<h3 class="font-bodoni text-4xl md:text-6xl mb-8 uppercase tracking-tighter transition-transform duration-500 group-hover:translate-x-4 titulo-estilo-apple">
							II. La Prótesis <span class="highlight-word">Técnica</span>
						</h3>
						<p class="font-inter font-extralight text-lg md:text-2xl leading-relaxed opacity-60 group-hover:opacity-100 transition-opacity max-w-4xl">
							La tecnología no es externa; es la infraestructura donde nuestra mente se anida. El neocórtex es ahora compartido con la máquina.
						</p>
					</div>
				</a>

				<a href="/tesis-03" class="block thesis-card w-full bento-glass p-8 md:p-16 rounded-[3rem] card-lift group min-h-[400px] flex flex-col md:flex-row gap-16 items-center mask-image-v">
					<div class="text-7xl md:text-9xl font-bodoni italic opacity-5 group-hover:opacity-20 transition-opacity">03</div>
					<div class="flex-1">
						<h3 class="font-bodoni text-4xl md:text-6xl mb-8 uppercase tracking-tighter transition-transform duration-500 group-hover:translate-x-4 titulo-estilo-apple">
							III. La Heurística <span class="highlight-word">Alterna</span>
						</h3>
						<p class="font-inter font-extralight text-lg md:text-2xl leading-relaxed opacity-60 group-hover:opacity-100 transition-opacity max-w-4xl">
							Lo "alternativo" no es verdad oculta, sino una herramienta diagnóstica para cartografiar los procesos de exclusión y amnesia programada.
						</p>
					</div>
				</a>

				<a href="/tesis-04" class="block thesis-card w-full bento-glass p-8 md:p-16 rounded-[3rem] card-lift group min-h-[400px] flex flex-col md:flex-row gap-16 items-center mask-image-v">
					<div class="text-7xl md:text-9xl font-bodoni italic opacity-5 group-hover:opacity-20 transition-opacity">04</div>
					<div class="flex-1">
						<h3 class="font-bodoni text-4xl md:text-6xl mb-8 uppercase tracking-tighter transition-transform duration-500 group-hover:translate-x-4 titulo-estilo-apple">
							IV. <span class="highlight-word">Semiotización</span>
						</h3>
						<p class="font-inter font-extralight text-lg md:text-2xl leading-relaxed opacity-60 group-hover:opacity-100 transition-opacity max-w-4xl">
							El cerebro siempre sintetiza mitos. Ante la IA, el riesgo no es perder el sentido, sino convertirnos en espectadores del sentido generado por el proxy.
						</p>
					</div>
				</a>
			</div>
		</section>

		<!-- MEDIA LAB SECTION -->
		<section id="media" class="px-6 md:px-16 py-32 bg-bg relative space-y-8">
			<div class="w-full flex justify-between items-end mb-12">
				<h2 class="font-bodoni text-5xl md:text-7xl leading-none titulo-estilo-apple">
					<span class="highlight-word">Media</span> Lab
				</h2>
				<p class="font-inter text-[10px] tracking-[0.4em] opacity-40 uppercase">Exploración de Nichos</p>
			</div>

			<!-- Media Lab Category Bentos -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<a href="/media" class="block bento-glass mask-image-v p-10 group cursor-pointer h-full">
					<div class="flex justify-between items-start mb-12">
						<h2 class="font-bodoni text-4xl italic tracking-tighter text-highlight group-hover:text-[#9F8CAE] transition-colors duration-500">Eventos</h2>
						<span class="text-3xl opacity-10 group-hover:opacity-100 group-hover:text-[#9F8CAE] transition-all group-hover:translate-x-4">→</span>
					</div>
					<p class="font-inter text-sm font-light opacity-60 group-hover:opacity-100 transition-opacity">Conferencias & Simposios internacionales.</p>
				</a>

				<a href="/media" class="block bento-glass mask-image-v p-10 group cursor-pointer h-full">
					<div class="flex justify-between items-start mb-12">
						<h2 class="font-bodoni text-4xl italic tracking-tighter text-highlight group-hover:text-[#9F8CAE] transition-colors duration-500">Podcast</h2>
						<span class="text-3xl opacity-10 group-hover:opacity-100 group-hover:text-[#9F8CAE] transition-all group-hover:translate-x-4">→</span>
					</div>
					<p class="font-inter text-sm font-light opacity-60 group-hover:opacity-100 transition-opacity">Arqueología de las ideas en formato audio.</p>
				</a>

				<a href="/media" class="block bento-glass mask-image-v p-10 group cursor-pointer h-full">
					<div class="flex justify-between items-start mb-12">
						<h2 class="font-bodoni text-4xl italic tracking-tighter text-highlight group-hover:text-[#9F8CAE] transition-colors duration-500">Lab</h2>
						<span class="text-3xl opacity-10 group-hover:opacity-100 group-hover:text-[#9F8CAE] transition-all group-hover:translate-x-4">→</span>
					</div>
					<p class="font-inter text-sm font-light opacity-60 group-hover:opacity-100 transition-opacity">Prototipado de nichos simbólicos.</p>
				</a>
			</div>

			<!-- Contact CTA -->
			<div class="w-full bento-glass p-8 md:p-20 flex flex-col md:flex-row gap-12 items-center rounded-[3rem] card-lift group min-h-[450px] mt-16 relative overflow-hidden">
				<div class="absolute -top-24 -right-24 w-64 h-64 bg-highlight/5 rounded-full blur-[100px]"></div>
				<div class="absolute -bottom-24 -left-24 w-64 h-64 bg-[#9F8CAE]/5 rounded-full blur-[100px]"></div>
				
				<div class="flex-1 relative z-10">
					<h3 class="font-bodoni text-4xl md:text-7xl font-bold leading-tight titulo-estilo-apple">
						¿Deseas explorar el <span class="highlight-word group-hover:!text-[#9F8CAE]">nicho</span>?
					</h3>
					<p class="font-inter mt-8 text-lg md:text-2xl font-extralight text-highlight/60 leading-relaxed max-w-2xl italic">
						"¡Quiero unirme al puzzle!"
					</p>
				</div>
				<div class="w-full md:w-auto relative z-10">
					<a href="mailto:info@greatpuzzle.project" class="cta-editorial">¡Unirse al Puzzle!</a>
				</div>
			</div>
		</section>
	</main>

	<!-- FOOTER -->
	<footer class="relative bg-bg border-t border-border pt-32 pb-12 px-6 md:px-16 overflow-hidden">
		<div class="lens-glow bottom-[-400px] left-1/2 -translate-x-1/2 opacity-20"></div>
		
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-24 relative z-10">
			<div class="space-y-10">
				<div class="flex items-center gap-6 group cursor-pointer">
					<img src="/puzzle.png" alt="Logo" class="w-12 h-auto brightness-150 grayscale group-hover:grayscale-0 transition-all duration-700" />
					<div class="font-gloock text-3xl md:text-4xl tracking-[0.15em] uppercase titulo-estilo-apple">THE GREAT PUZZLE PROJECT</div>
				</div>
				<p class="font-inter text-[10px] md:text-xs uppercase tracking-[0.4em] opacity-30 leading-loose max-w-md">
					Investigación sobre la arquitectura técnica del olvido y la gestión del sentido.
				</p>
			</div>

			<div class="space-y-6">
				<h4 class="font-inter text-[10px] uppercase tracking-[0.5em] text-highlight mb-8 opacity-50">Exploración</h4>
				<ul class="space-y-4 font-inter text-sm font-light opacity-60">
					<li><a href="/proyectos" class="hover:text-[#9F8CAE] transition-colors">Proyectos</a></li>
					<li><a href="/tesis" class="hover:text-[#9F8CAE] transition-colors">Tesis</a></li>
					<li><a href="/media" class="hover:text-[#9F8CAE] transition-colors">Media Lab</a></li>
				</ul>
			</div>

			<div class="space-y-8">
				<h4 class="font-inter text-[10px] uppercase tracking-[0.5em] text-highlight mb-8 opacity-50">Conexión</h4>
				<div class="flex flex-wrap gap-4">
					<!-- X -->
					<a href="#" class="w-12 h-12 rounded-full border border-border/40 flex items-center justify-center opacity-40 transition-all duration-500 hover:opacity-100 hover:text-[#9F8CAE] hover:border-[#9F8CAE]/50 hover:shadow-[0_0_20px_rgba(159,140,174,0.3)]">
						<svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
					</a>
					<!-- Instagram -->
					<a href="#" class="w-12 h-12 rounded-full border border-border/40 flex items-center justify-center opacity-40 transition-all duration-500 hover:opacity-100 hover:text-[#9F8CAE] hover:border-[#9F8CAE]/50 hover:shadow-[0_0_20px_rgba(159,140,174,0.3)]">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
					</a>
					<!-- LinkedIn -->
					<a href="#" class="w-12 h-12 rounded-full border border-border/40 flex items-center justify-center opacity-40 transition-all duration-500 hover:opacity-100 hover:text-[#9F8CAE] hover:border-[#9F8CAE]/50 hover:shadow-[0_0_20px_rgba(159,140,174,0.3)]">
						<svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
					</a>
					<!-- Spotify -->
					<a href="#" class="w-12 h-12 rounded-full border border-border/40 flex items-center justify-center opacity-40 transition-all duration-500 hover:opacity-100 hover:text-[#9F8CAE] hover:border-[#9F8CAE]/50 hover:shadow-[0_0_20px_rgba(159,140,174,0.3)]">
						<svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 0c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm5.59 17.318c-.22.362-.689.47-1.05.249-2.83-1.728-6.391-2.121-10.589-1.161-.413.095-.823-.164-.917-.577s.164-.822.577-.917c4.591-1.05 8.528-.598 11.73 1.356.36.219.472.689.249 1.05zm1.488-3.262c-.277.449-.863.591-1.311.313-3.238-1.99-8.175-2.565-11.999-1.404-.509.155-1.04-.132-1.196-.64s.131-1.042.64-1.197c4.372-1.328 9.807-.68 13.555 1.624.448.277.59.862.311 1.304zm.131-3.418c-3.882-2.305-10.287-2.518-14.015-1.386-.595.18-1.23-.158-1.411-.753-.18-.594.158-1.23.753-1.41 4.288-1.302 11.353-1.055 15.82 1.597.535.318.708 1.008.39 1.543s-1.008.709-1.537.409z"/></svg>
					</a>
				</div>
			</div>
		</div>

		<div class="border-t border-border/30 pt-12 text-center text-[10px] uppercase tracking-[0.5em] opacity-40">
			Xavier Benítez © 2026 • Buenos Aires • Argentina
		</div>
	</footer>

	<script>
		import gsap from 'gsap';
		import { ScrollTrigger } from 'gsap/ScrollTrigger';
		gsap.registerPlugin(ScrollTrigger);

		// Fade in sections
		gsap.utils.toArray('section').forEach((section: any) => {
			gsap.from(section, {
				scrollTrigger: {
					trigger: section,
					start: 'top 85%',
				},
				y: 50,
				opacity: 0,
				duration: 1.2,
				ease: 'power2.out'
			});
		});
	</script>
</Layout>

<style>
	.lens-glow {
		position: absolute;
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, rgba(159, 140, 174, 0.1) 0%, transparent 70%);
		pointer-events: none;
		z-index: 0;
	}
</style>
