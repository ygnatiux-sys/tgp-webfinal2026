---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Media Lab | The Great Puzzle Project">
	<main class="min-h-screen bg-bg text-primary px-6 md:px-16 pt-32 pb-20">
		<!-- HEADER -->
		<div class="max-w-7xl mx-auto mb-20 flex justify-between items-center">
			<div>
				<h1 class="font-gloock text-4xl md:text-6xl tracking-tighter uppercase titulo-estilo-apple">Media Lab</h1>
				<p class="font-inter text-[10px] uppercase tracking-[0.5em] opacity-40 mt-4">Exploración Transmedia & Simbólica</p>
			</div>
			<a href="/#media" class="cta-glass !rounded-full !px-8 !py-2 !text-[9px] uppercase tracking-widest group">
				<span class="group-hover:-translate-x-1 inline-block transition-transform">←</span> Volver
			</a>
		</div>

		<div class="max-w-7xl mx-auto space-y-32">
			
			<!-- SECTION 01: PODCAST -->
			<section class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
				<div class="lg:col-span-2 relative aspect-video md:aspect-[16/7] rounded-[2.5rem] overflow-hidden bento-glass group shadow-2xl">
					<img src="/media-podcast.png" alt="Podcast Arqueología" class="absolute inset-0 w-full h-full object-cover grayscale brightness-50 transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0 group-hover:brightness-75" />
					<div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-90"></div>
					
					<div class="absolute top-8 left-8 z-20">
						<span class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-60">Podcast / Arqueología de las Ideas</span>
					</div>

					<div class="absolute bottom-8 left-8 right-8 z-20">
						<h2 class="font-bodoni text-4xl md:text-6xl font-bold mb-4 titulo-estilo-apple tracking-tighter">Arqueología de las Ideas</h2>
						<p class="font-inter text-sm md:text-base font-extralight leading-relaxed opacity-80 max-w-2xl">
							Un espacio de escucha profunda donde desenterramos las capas de sentido que sostienen nuestra realidad técnica contemporánea.
						</p>
					</div>
				</div>

				<div class="space-y-6 h-full">
					<div class="bento-glass p-8 rounded-[2rem] space-y-6 flex flex-col justify-between h-full">
						<div>
							<h4 class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-40 mb-6">Escuchar en</h4>
							<div class="space-y-4">
								<a href="#" class="flex items-center gap-4 group/item">
									<div class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center group-hover/item:border-[#9F8CAE] transition-all">
										<svg class="w-4 h-4 fill-current opacity-60 group-hover/item:text-[#9F8CAE]" viewBox="0 0 24 24"><path d="M12 0c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm1.488 17.318c-.22.362-.689.47-1.05.249-2.83-1.728-6.391-2.121-10.589-1.161-.413.095-.823-.164-.917-.577s.164-.822.577-.917c4.591-1.05 8.528-.598 11.73 1.356.36.219.472.689.249 1.05z"/></svg>
									</div>
									<span class="text-sm font-light opacity-60 group-hover/item:opacity-100 transition-opacity">Spotify</span>
								</a>
								<a href="#" class="flex items-center gap-4 group/item">
									<div class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center group-hover/item:border-[#9F8CAE] transition-all">
										<svg class="w-4 h-4 fill-current opacity-60 group-hover/item:text-[#9F8CAE]" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 4-8 4z"/></svg>
									</div>
									<span class="text-sm font-light opacity-60 group-hover/item:opacity-100 transition-opacity">YouTube</span>
								</a>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- SECTION 02: EVENTOS -->
			<section class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
				<div class="lg:col-span-2 relative aspect-video md:aspect-[16/7] rounded-[2.5rem] overflow-hidden bento-glass group shadow-2xl">
					<img src="/media-events.png" alt="Eventos y Simposios" class="absolute inset-0 w-full h-full object-cover grayscale brightness-50 transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0 group-hover:brightness-75" />
					<div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-90"></div>
					
					<div class="absolute top-8 left-8 z-20">
						<span class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-60">Eventos / Simposios</span>
					</div>

					<div class="absolute bottom-8 left-8 right-8 z-20">
						<h2 class="font-bodoni text-4xl md:text-6xl font-bold mb-4 titulo-estilo-apple tracking-tighter">Simposios & Encuentros</h2>
						<p class="font-inter text-sm md:text-base font-extralight leading-relaxed opacity-80 max-w-2xl">
							Instancias de diálogo presencial y virtual para la co-construcción de sentido en la era de la inteligencia artificial.
						</p>
					</div>
				</div>

				<div class="space-y-6 h-full">
					<div class="bento-glass p-8 rounded-[2rem] h-full">
						<h4 class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-40 mb-6">Próximos</h4>
						<ul class="space-y-6">
							<li class="border-b border-white/5 pb-4">
								<p class="text-[10px] text-[#9F8CAE] uppercase tracking-widest mb-1">Junio 2026</p>
								<p class="text-sm font-light">Neuroantropología de la Imagen</p>
							</li>
							<li class="pb-4">
								<p class="text-[10px] text-[#9F8CAE] uppercase tracking-widest mb-1">Agosto 2026</p>
								<p class="text-sm font-light">La Prótesis de la Memoria</p>
							</li>
						</ul>
					</div>
				</div>
			</section>

		</div>
	</main>
</Layout>
