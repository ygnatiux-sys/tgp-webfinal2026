---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tesis | The Great Puzzle Project">
	<main class="min-h-screen bg-bg text-primary px-6 md:px-16 pt-32 pb-20">
		<!-- HEADER / VOLVER -->
		<div class="max-w-7xl mx-auto mb-20 flex justify-between items-center">
			<div>
				<h1 class="font-gloock text-4xl md:text-6xl tracking-tighter uppercase titulo-estilo-apple">El Archivo de las Tesis</h1>
				<p class="font-inter text-[10px] uppercase tracking-[0.5em] opacity-40 mt-4">Arquitectura del sentido & Memoria Técnica</p>
			</div>
			<a href="/#tesis" class="cta-glass rounded-full! px-8! py-2! text-[9px]! uppercase tracking-widest group">
				<span class="group-hover:-translate-x-1 inline-block transition-transform">←</span> Volver
			</a>
		</div>

		<div class="max-w-7xl mx-auto space-y-32">
			
			<!-- THESIS 01: EL SAPIENS ARQUITECTO -->
			<section class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
				<!-- Main Profile Card -->
				<div class="lg:col-span-2 relative aspect-video md:aspect-16/7 rounded-[2.5rem] overflow-hidden bento-glass group shadow-2xl">
					<img src="/tesis-01.png" alt="Tesis 01" class="absolute inset-0 w-full h-full object-cover grayscale brightness-50 transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0 group-hover:brightness-75" />
					<div class="absolute inset-0 bg-linear-to-t from-bg via-transparent to-transparent opacity-90"></div>
					
					<div class="absolute top-8 left-8 z-20">
						<span class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-60">Tesis 01 / Antropología</span>
					</div>

					<div class="absolute bottom-8 left-8 right-8 z-20">
						<h2 class="font-bodoni text-4xl md:text-6xl font-bold mb-4 titulo-estilo-apple tracking-tighter">I. El Sapiens Arquitecto</h2>
						<p class="font-inter text-sm md:text-base font-extralight leading-relaxed opacity-80 max-w-2xl">
							No habitamos mundos materiales, sino relatos. La civilización es un mecanismo de defensa neurocognitivo proyectado a escala monumental para gestionar la angustia del vacío.
						</p>
					</div>
				</div>

				<!-- Credits/Meta Sidebar -->
				<div class="space-y-6">
					<div class="bento-glass p-8 rounded-4xl space-y-8">
						<div>
							<h4 class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-40 mb-4">Créditos</h4>
							<div class="space-y-4">
								<div>
									<p class="text-xs font-bold">Investigación Principal</p>
									<p class="text-xs opacity-50">Xavier Benítez</p>
								</div>
								<div>
									<p class="text-xs font-bold">Teoría Técnica</p>
									<p class="text-xs opacity-50">Archivo Vivo • Lab 01</p>
								</div>
							</div>
						</div>
						<div class="pt-6 border-t border-white/5">
							<button class="w-full py-3 rounded-full border border-white/10 text-[9px] uppercase tracking-widest hover:bg-[#9F8CAE] hover:text-white transition-all duration-500">
								Descargar Paper (PDF)
							</button>
						</div>
					</div>
					
					<div class="bento-glass p-8 rounded-4xl space-y-8">
						<h4 class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-40 mb-6">Lectura</h4>
						<a href="/tesis-04" class="cta-glass w-full text-center py-4 rounded-xl text-[10px] uppercase tracking-widest block group-hover:bg-highlight group-hover:text-bg transition-all">Leer Tesis Completa</a>
					</div>

					<div class="bento-glass p-8 rounded-4xl">
						<h4 class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-40 mb-4">Conceptos Clave</h4>
						<div class="flex flex-wrap gap-2">
							<span class="px-3 py-1 bg-white/5 rounded-full text-[9px] border border-white/5 opacity-60">Neurohistoria</span>
							<span class="px-3 py-1 bg-white/5 rounded-full text-[9px] border border-white/5 opacity-60">Mito</span>
							<span class="px-3 py-1 bg-white/5 rounded-full text-[9px] border border-white/5 opacity-60">Estructura</span>
						</div>
					</div>
				</div>
			</section>

			<!-- THESIS 02: LA PRÓTESIS TÉCNICA -->
			<section class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
				<!-- Main Profile Card -->
				<div class="lg:col-span-2 relative aspect-video md:aspect-16/7 rounded-[2.5rem] overflow-hidden bento-glass group shadow-2xl">
					<img src="/tesis-04.png" alt="Tesis 04" class="absolute inset-0 w-full h-full object-cover grayscale brightness-50 transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0 group-hover:brightness-75" />
					<div class="absolute inset-0 bg-linear-to-t from-bg via-transparent to-transparent opacity-90"></div>
					
					<div class="absolute top-8 left-8 z-20">
						<span class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-60">Tesis 02 / Tecnología</span>
					</div>

					<div class="absolute bottom-8 left-8 right-8 z-20">
						<h2 class="font-bodoni text-4xl md:text-6xl font-bold mb-4 titulo-estilo-apple tracking-tighter">II. La Prótesis Técnica</h2>
						<p class="font-inter text-sm md:text-base font-extralight leading-relaxed opacity-80 max-w-2xl">
							La tecnología no es externa; es la infraestructura donde nuestra mente se anida. El neocórtex es ahora compartido con la máquina, creando un sistema de memoria externalizado.
						</p>
					</div>
				</div>

				<!-- Credits/Meta Sidebar -->
				<div class="space-y-6">
					<div class="bento-glass p-8 rounded-4xl space-y-8">
						<div>
							<h4 class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-40 mb-4">Créditos</h4>
							<div class="space-y-4">
								<div>
									<p class="text-xs font-bold">Colaboradores</p>
									<p class="text-xs opacity-50">Stiegler Group • Benítez Lab</p>
								</div>
								<div>
									<p class="text-xs font-bold">Ubicación</p>
									<p class="text-xs opacity-50">Buenos Aires / Virtual</p>
								</div>
							</div>
						</div>
						<div class="pt-6 border-t border-white/5">
							<button class="w-full py-3 rounded-full border border-white/10 text-[9px] uppercase tracking-widest hover:bg-[#9F8CAE] hover:text-white transition-all duration-500">
								Ver Simposio
							</button>
						</div>
					</div>
				</div>
			</section>

			<!-- THESIS 03: LA HEURÍSTICA ALTERNA -->
			<section class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
				<!-- Main Profile Card -->
				<div class="lg:col-span-2 relative aspect-video md:aspect-16/7 rounded-[2.5rem] overflow-hidden bento-glass group shadow-2xl">
					<img src="/tesis_03_archaeology_1777714660234.png" alt="La Heurística Alterna" class="absolute inset-0 w-full h-full object-cover grayscale brightness-50 transition-all duration-1000 group-hover:scale-105 group-hover:grayscale-0 group-hover:brightness-75" />
					<div class="absolute inset-0 bg-linear-to-t from-bg via-transparent to-transparent opacity-90"></div>
					
					<div class="absolute top-8 left-8 z-20">
						<span class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-60">Tesis 03 / Arqueología</span>
					</div>

					<div class="absolute bottom-8 left-8 right-8 z-20">
						<h2 class="font-bodoni text-4xl md:text-6xl font-bold mb-4 titulo-estilo-apple tracking-tighter">III. La Heurística Alterna</h2>
						<p class="font-inter text-sm md:text-base font-extralight leading-relaxed opacity-80 max-w-2xl">
							Lo "alternativo" no es verdad oculta, sino una herramienta diagnóstica para cartografiar los procesos de exclusión y amnesia programada del Archivo Vivo.
						</p>
					</div>
				</div>

				<!-- Credits/Meta Sidebar -->
				<div class="space-y-6">
					<div class="bento-glass p-8 rounded-4xl space-y-8">
						<div>
							<h4 class="font-inter text-[10px] uppercase tracking-[0.4em] opacity-40 mb-4">Créditos</h4>
							<div class="space-y-4">
								<div>
									<p class="text-xs font-bold">Metodología</p>
									<p class="text-xs opacity-50">Arqueología del Sentido</p>
								</div>
							</div>
						</div>
						<div class="pt-6 border-t border-white/5">
							<button class="w-full py-3 rounded-full border border-white/10 text-[9px] uppercase tracking-widest hover:bg-[#9F8CAE] hover:text-white transition-all duration-500">
								Explorar Excavación
							</button>
						</div>
					</div>
				</div>
			</section>

		</div>
	</main>
</Layout>
